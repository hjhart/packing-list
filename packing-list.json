      "type": "number"
    },
    {
      "id": "family",
      "text": "Family trip?",
      "type": "boolean",
      "default": true,
      "activateTagsIfTrue": [
        "family"
      ]
    },
    {
      "id": "henry",
      "text": "Packing for Henry?",
